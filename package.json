{
  "name": "church",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "dotenv -e .env -- sh -c \"NODE_OPTIONS='--import ./instrument.server.mjs' vite dev --port 3000\"",
    "build": "tsc --noEmit && vite build && mkdir -p .output/server/ && cp instrument.server.mjs .output/server/instrument.server.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "format": "biome format",
    "lint": "biome lint",
    "check": "ultracite check",
    "post-cta-init": "bunx --bun create-db@latest --user-agent tanstack/tsrouter",
    "db:generate": "dotenv -e .env -- prisma generate",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:migrate": "dotenv -e .env -- prisma migrate dev",
    "db:reset": "dotenv -e .env -- prisma migrate reset",
    "db:studio": "dotenv -e .env -- prisma studio",
    "db:seed": "dotenv -e .env -- prisma db seed",
    "db:dev": "dotenv -e .env -- prisma dev",
    "db:migrate:prod": "PROD=true dotenv -e .env -- prisma migrate deploy",
    "start": "node --import ./.output/server/instrument.server.mjs .output/server/index.mjs",
    "fix": "ultracite fix",
    "inngest-cli": "inngest-cli dev",
    "email:dev": "email dev",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.996.0",
    "@aws-sdk/s3-request-presigner": "^3.996.0",
    "@base-ui/react": "^1.2.0",
    "@brvhprince/termii-js": "^2.0.0",
    "@davidbolaji/termii-node": "^1.0.3",
    "@faker-js/faker": "^10.0.0",
    "@fontsource/geist": "^5.2.8",
    "@fontsource/geist-mono": "^5.2.7",
    "@google/generative-ai": "^0.24.1",
    "@orpc/client": "^1.13.0",
    "@orpc/json-schema": "^1.13.0",
    "@orpc/openapi": "^1.13.0",
    "@orpc/server": "^1.13.0",
    "@orpc/tanstack-query": "^1.13.0",
    "@orpc/zod": "^1.13.0",
    "@posthog/react": "^1.7.0",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@react-email/components": "^1.0.8",
    "@react-email/render": "^2.0.4",
    "@sentry/tanstackstart-react": "^10.34.0",
    "@t3-oss/env-core": "^0.13.8",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/match-sorter-utils": "^8.19.4",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-form": "^1.28.3",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-query-devtools": "^5.84.2",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/react-table": "^8.21.2",
    "@tanstack/router-plugin": "^1.132.0",
    "@tanstack/store": "^0.9.1",
    "@types/nodemailer": "^7.0.11",
    "better-auth": "^1.4.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "inngest": "^3.52.3",
    "lucide-react": "^0.561.0",
    "motion": "^12.34.3",
    "next-themes": "^0.4.6",
    "nitro": "^3.0.1-alpha.2",
    "nodemailer": "^8.0.1",
    "nuqs": "^2.8.8",
    "posthog-js": "^1.335.4",
    "prisma": "^7.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-email": "^5.2.8",
    "sonner": "^2.0.7",
    "srvx": "^0.11.8",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.3.6",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^4.1.11",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@react-email/preview-server": "5.2.8",
    "@tanstack/devtools-vite": "^0.3.11",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "inngest-cli": "^1.17.1",
    "jsdom": "^27.0.0",
    "pridepack": "^2.6.4",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2",
    "ultracite": "7.2.3",
    "vite": "^7.1.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  },
  "trustedDependencies": [
    "@sentry/cli",
    "core-js",
    "inngest-cli",
    "protobufjs"
  ]
}
